# Agentic Search Environment Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# Anthropic API Key (required for all approaches)
# =============================================================================
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# LLM Model Configuration (used by all 3 approaches)
# =============================================================================
# Default: claude-sonnet-4-5-20250929 (Claude Sonnet 4.5)
# Each script has a built-in fallback if this is not set or invalid
LLM_MODEL=claude-sonnet-4-5-20250929

# =============================================================================
# Optional: LangSmith Tracing (cloud-based trace visualization)
# =============================================================================
# LANGCHAIN_TRACING=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# DEEPAGENTS_LANGSMITH_PROJECT=doc-search-traces
