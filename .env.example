# DeepAgents CLI Environment Configuration
# Copy this file to .env.anthropic and fill in your credentials

# =============================================================================
# Anthropic API Key (required for Claude models)
# =============================================================================
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Optional: GitHub Token (for GitHub Models API - alternative LLM provider)
# =============================================================================
# GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# Optional: LangSmith Tracing (cloud-based trace visualization)
# =============================================================================
# LANGCHAIN_TRACING=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# DEEPAGENTS_LANGSMITH_PROJECT=doc-search-traces
